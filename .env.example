# =============================================================================
# go-api-template — Archivo de ejemplo de variables de entorno
# Copia este archivo a .env y ajusta los valores según tu entorno
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Servidor
# -----------------------------------------------------------------------------

# Puerto en el que escucha la API
APP_PORT=8080

# Entorno de ejecución: development | production
# En production se desactivan los logs detallados de Gin y se activa GinReleaseMode
APP_ENV=development

# -----------------------------------------------------------------------------
# Base de datos
# -----------------------------------------------------------------------------

# Ruta al archivo SQLite. Para Docker usa ./data/data.db
DB_PATH=./data.db

# -----------------------------------------------------------------------------
# JWT — JSON Web Tokens
# -----------------------------------------------------------------------------

# Secreto usado para firmar los tokens. ¡Cámbialo en producción!
# Genera uno seguro con: openssl rand -hex 32
JWT_SECRET=change_me_use_a_long_random_string_in_production

# Tiempo de expiración del access token (formato de time.Duration de Go)
# Ejemplos: 15m, 1h, 24h
JWT_ACCESS_EXPIRY=15m

# Tiempo de expiración del refresh token
# Ejemplos: 168h (7 días), 720h (30 días)
JWT_REFRESH_EXPIRY=168h

# -----------------------------------------------------------------------------
# CORS — Cross-Origin Resource Sharing
# -----------------------------------------------------------------------------

# Orígenes permitidos, separados por coma. Usa * para permitir todos.
# Ejemplos: http://localhost:3000,https://miapp.com
CORS_ORIGINS=*

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Nivel de log: debug | info | warn | error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------

# Activa o desactiva el rate limiting globalmente. true | false
# En false se ignoran todos los límites (útil para tests o desarrollo local)
RATE_LIMIT_ENABLED=true

# -----------------------------------------------------------------------------
# Swagger / Documentación
# -----------------------------------------------------------------------------

# Activa la UI de Swagger en GET /docs/index.html. true | false
# Recomendado: false en producción para no exponer la documentación
SWAGGER_ENABLED=true
